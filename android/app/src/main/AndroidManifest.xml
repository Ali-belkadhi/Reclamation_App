<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- PERMISSIONS                                                 -->
    <!-- ═══════════════════════════════════════════════════════════ -->

    <!-- Accès Internet (indispensable pour FCM) -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Permission POST_NOTIFICATIONS (Android 13+ / API 33+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Réception des notifications en arrière-plan (wake lock) -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Vibration pour les notifications -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- APPLICATION                                                 -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <application
        android:label="reclamation_attijari"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher">

        <!-- ── Activité principale Flutter ── -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">

            <meta-data
                android:name="io.flutter.embedding.android.NormalTheme"
                android:resource="@style/NormalTheme" />

            <!-- Intent filter principal (lanceur) -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Intent filter pour l'ouverture depuis une notification FCM -->
            <intent-filter>
                <action android:name="FLUTTER_NOTIFICATION_CLICK" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- ── Service Firebase Messaging (réception des messages FCM) ── -->
        <service
            android:name="com.google.firebase.messaging.FirebaseMessagingService"
            android:exported="false">
            <intent-filter android:priority="-500">
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- ── Icône de notification par défaut (optionnel mais recommandé) ── -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@mipmap/ic_launcher" />

        <!-- ── Couleur de notification par défaut ── -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_color"
            android:resource="@color/notification_color" />

        <!-- ── Canal de notification par défaut (Android 8+) ── -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="fcm_high_importance_channel" />

        <!-- Flutter embedding version 2 -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />

    </application>

    <!-- Nécessaire pour la résolution d'activités texte (Flutter plugin) -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT" />
            <data android:mimeType="text/plain" />
        </intent>
    </queries>

</manifest>
